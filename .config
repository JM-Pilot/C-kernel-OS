#
# Automatically generated file; DO NOT EDIT.
# CkOS kernel setup
#

#
# General config
#
# CONFIG_CMDLINE is not set

#
# Visuals and aesthetic features
#
CONFIG_ADDITIONAL_VER=""
CONFIG_COLOR_FB_TEXT=y

#
# Text colors from settings below are in XRGB
#
CONFIG_COLOR_FB_FG=0x00AAAAAA
CONFIG_COLOR_FB_BG=0x00000000
CONFIG_ANIMATIONS=y
CONFIG_PRINTK_TIME=y
CONFIG_LOGO=y
CONFIG_LOGLEVEL=7

#
# Devices
#
CONFIG_SERIAL=y
CONFIG_COM1=y

#
# COM2 is the terminal's COM port if ran using the `qemu` target
#
CONFIG_COM2=y
CONFIG_PS2_KB=y
CONFIG_PCSPK=y

#
# Not to confuse with a speaker, like audio jack or optical cables.
#
